# 开发环境
NODE_ENV='development'
# 应用标题
VITE_APP_TITLE='职引未来'
# 对应后端的接口地址（完整地址）
VITE_API_URL=http://localhost:8080
# 对应后端的服务器地址
VITE_SERVER=http://localhost:8080

# ==================== Mock 配置 ====================
# 是否启用 Mock 数据（启用后所有API返回模拟数据）
VITE_ENABLE_MOCK=false

# Mock 场景：success(成功) | partial(部分缺失) | processing(异步解析) | failed(失败)
VITE_MOCK_SCENARIO=success

