<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backend.careerplanningbackend.mapper.UserMapper">
    <insert id="register" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_stu (username, password, email, avatar)
        VALUES (#{username}, #{password}, #{email}, #{avatar})
    </insert>
    <update id="forget">
        update user_stu
        set password=#{password}
        where username=#{username} and email=#{email}
    </update>
    <update id="edit">
        update user_stu
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="email != null">email = #{email},</if>
            <if test="info != null">info = #{info},</if>
        </set>
        <where>
            id = #{id}
        </where>
    </update>
    <update id="updateAvatar">
        update user_stu
        set avatar=#{upload}
        <where>
            id = #{id}
        </where>
    </update>
    <!--    <sql id="baseColumn">-->
<!--        id, username, nickname, email, avatar, status, create_time, update_time-->
<!--    </sql>-->
    
    <select id="selectByUsername" resultType="com.backend.careerplanningbackend.domain.po.User">
        SELECT id, username, password, nickname, avatar, info, email, status, role
        FROM user_stu
        WHERE username = #{username}
    </select>
    <select id="selectByEmail" resultType="com.backend.careerplanningbackend.domain.po.User">
        SELECT id, username, password, nickname, avatar, email, status
        FROM user_stu
        WHERE email = #{email}
    </select>
    <select id="getUserOneInfo" resultType="com.backend.careerplanningbackend.domain.po.User">
        select id, username
        from user_stu
        where id = #{id}
    </select>
<!--    <select id="getUserInfo" resultType="com.backend.careerplanningbackend.domain.dto.UserDTO">-->
<!--        select id, username, nickname, email, avatar, info-->
<!--        from user_stu-->
<!--        where id = #{id}-->
<!--    </select>-->
    <select id="getUserInfo" resultType="com.backend.careerplanningbackend.domain.dto.UserDTO">
        select *
        from user_stu
        where id = #{id}
    </select>
