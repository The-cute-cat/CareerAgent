# ==================== CareerAgent Docker 环境变量模板 ====================
# 复制为 .env 使用:  cp .env.example .env
# 然后根据实际环境修改各密码和配置

# ---- 端口映射（可选，不填则使用默认值）----
MYSQL_PORT=3306
REDIS_PORT=6379
NEO4J_PORT=7474
NEO4J_BOLT_PORT=7687
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
BACKEND_PORT=8080
FRONTEND_PORT=8081

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=CareerAgent_root_2025
MYSQL_DATABASE=career_backend
MYSQL_USER=career
MYSQL_PASSWORD=career_dev_2025

# ---- Redis ----
REDIS_PASSWORD=redis_dev_2025

# ---- Neo4j ----
NEO4J_PASSWORD=neo4j_dev_2025

# ---- RabbitMQ ----
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=mq_dev_2025
RABBITMQ_VHOST=/user-career-agent

# ---- 后端 Spring Boot (application-docker.yaml 会读取) ----
# 数据库连接（Docker 内部使用服务名）
DB_HOST=mysql
DB_PORT=3306
DB_NAME=career_backend
DB_USERNAME=career
DB_PASSWORD=career_dev_2025

# Redis 连接
REDIS_HOST=redis
REDIS_USERNAME=default
REDIS_CONN_PASSWORD=redis_dev_2025

# 邮件配置
MAIL_USERNAME_QQ=your_qq@qq.com
MAIL_PASSWORD_QQ=your_smtp_auth_code

# 阿里云 OSS
ALY_OSS_ACCESS_KEY_ID=your_access_key_id
ALY_OSS_ACCESS_KEY_SECRET=your_access_key_secret
ALY_OSS_ACCESS_KEY_ENDPOINT=https://oss-cn-guangzhou.aliyuncs.com
ALY_OSS_ACCESS_KEY_BUCKET=career-planning-backend

# JWT & Token
JWT_SECRET=ThisIsSecretKeyForHelloWorldProject2025
SECRET=CareerAgent

# AI 服务地址（Docker 内部服务名）
AI_SERVICE_URL=http://ai-service:9000

# 支付宝（沙箱）
ALIPAY_APP_ID=9021000156657096
ALIPAY_PRIVATE_KEY=your_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key
