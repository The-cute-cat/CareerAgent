# ==================== 环境变量模板 ====================
# 使用说明:
#   1. 本地开发: 复制为 .env 并填写实际值（cp .env.example .env）
#   2. Docker Compose: 无需 .env 文件，所有变量已在 docker-compose.yml 中设置默认值
#      如需覆盖默认值，可创建 .env 文件或通过环境变量传入
#
# 注意: <placeholder> 表示需要替换为实际值的配置项

# ==================== 端口配置 ====================

MYSQL_PORT=3306 # MySQL 默认端口
REDIS_PORT=6379 # Redis 默认端口
NEO4J_PORT=7474 # Neo4j HTTP 端口
NEO4J_BOLT_PORT=7687 # Neo4j Bolt 端口
RABBITMQ_AMQP_PORT=5672 # RabbitMQ AMQP 端口
RABBITMQ_MGMT_PORT=15672 # RabbitMQ 管理端口
MILVUS_PORT=19530 # Milvus 默认端口
MILVUS_MANAGEMENT_PORT=9091 # Milvus 管理端口
BACKEND_PORT=8080 # 后端服务端口
FRONTEND_PORT=8081 # 前端服务端口
AI_SERVICE_PORT=9000 # AI 服务端口

# ==================== 基础设施服务 ====================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=CareerAgent_root_2025 # MySQL root 用户密码
MYSQL_DATABASE=career_backend             # MySQL 数据库名
MYSQL_USER=career                         # MySQL 用户名
MYSQL_PASSWORD=career_dev_2025            # MySQL 用户密码

# ---- Redis ----
REDIS_PASSWORD=redis_dev_2025             # Redis 密码

# ---- Neo4j ----
NEO4J_PASSWORD=neo4j_dev_2025             # Neo4j 密码

# ---- RabbitMQ ----
RABBITMQ_USER=admin                       # RabbitMQ 用户名
RABBITMQ_PASSWORD=mq_dev_2025             # RabbitMQ 密码
RABBITMQ_VHOST=/user-career-agent         # RabbitMQ vhost

# ==================== 其他公共配置 ====================
COMMUNICATION_TOKEN_SECRET=CareerAgent    # 后端与AI服务通信令牌密钥



# ==================== 后端配置 ====================
# 邮件配置
# MAIL_HOST=smtp.qq.com
# MAIL_PORT=587
MAIL_USERNAME=<EMAIL>
MAIL_PASSWORD=<PASSWORD>

# 阿里云 OSS 配置
ALY_OSS_ACCESS_KEY_ENDPOINT=<endpoint>
ALY_OSS_ACCESS_KEY_ID=<access_key_id>
ALY_OSS_ACCESS_KEY_SECRET=<access_key_secret>
ALY_OSS_ACCESS_KEY_BUCKET=<bucket_name>

# JWT 配置
JWT_SECRET=ThisIsSecretKeyForHelloWorldProject2025

# 支付宝配置
ALIPAY_APP_ID=<app_id>
ALIPAY_PRIVATE_KEY=<private_key>
ALIPAY_PUBLIC_KEY=<public_key>
# 支付回调地址（Docker 环境下需设置为外网可访问的地址，默认使用 SERVER_HOST:BACKEND_PORT）
# ALIPAY_NOTIFY_URL=http://your-domain.com/api/alipay/toSuccess
# ALIPAY_RETURN_URL=http://your-domain.com/api/alipay/toSuccess

# 服务主机地址（用于生成回调 URL，Docker 环境下需设置为主机的外网 IP 或域名）
# SERVER_HOST=localhost

# ========================= AI服务配置 ====================
# 基础 LLM 配置（详细配置见AI服务端config.yaml）
# LLM__MODEL_NAME=qwen-max
# LLM__BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM__API_KEY=<api_key> # LLM API Key

# Milvus 的 Zilliz 云服务配置(可选)
# MILVUS__CLOUD__URL=<url>
# MILVUS__CLOUD__TOKEN=<token>

# 路径配置，需要绝对路径，否则使用默认路径
# PATH_CONFIG__TEMP__PATH=/app/temp
# PATH_CONFIG__TEMP__EXIT_IS_CLEAN=true
# PATH_CONFIG__TEMP__RUN_IS_CLEAN=false
# PATH_CONFIG__LOG=/app/logs
# PATH_CONFIG__DATA=/app/data

# LangSmith 配置
LANGCHAIN_TRACING=True
LANGCHAIN_API_KEY=<api_key>
LANGSMITH_ENDPOINT=<endpoint>
LANGCHAIN_PROJECT=<project>

# 代码能力配置
# CODE_ABILITY__GITHUB_TOKEN=<token> # GitHub 令牌，需具备 repo 权限
# CODE_ABILITY__GITEE_TOKEN=<token>  # Gitee 令牌，需具备 repo 权限

# 对话模型
# CONVERSATION__AGENT__MODEL_NAME=deepseek-reasoner
# CONVERSATION__AGENT__BASE_URL=https://api.deepseek.com
CONVERSATION__AGENT__API_KEY=<api_key>

#禁用LiteLLM远程获取，直接使用本地缓存
LITELLM_LOCAL_MODEL_COST_MAP=True